<!-- pages/stats/stats.wxml -->
<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">📊 出勤统计看板</text>
    <text class="subtitle">{{role === 'student' ? '个人出勤分析' : '班级出勤管理'}}</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-tip">⏳ 加载中...</view>

  <!-- ===== 学生视图 ===== -->
  <view wx:elif="{{role === 'student'}}" class="student-view">
    <!-- 汇总卡片 -->
    <view class="summary-cards">
      <view class="card">
        <text class="card-number">{{studentSummary.attendance_rate || 0}}%</text>
        <text class="card-label">出勤率</text>
      </view>
      <view class="card">
        <text class="card-number">{{studentSummary.total_sessions || 0}}</text>
        <text class="card-label">总签到次数</text>
      </view>
      <view class="card">
        <text class="card-number">{{studentSummary.leave_count || 0}}</text>
        <text class="card-label">已批准请假</text>
      </view>
    </view>

    <!-- 按课程分类统计 -->
    <view class="section">
      <view class="section-title">📚 课程出勤明细</view>
      <view wx:if="{{studentCourseStats.length > 0}}">
        <view class="course-item" wx:for="{{studentCourseStats}}" wx:key="course_name">
          <text class="course-name">{{item.course_name}}</text>
          <text class="course-rate">出勤率 {{item.rate}}%</text>
          <text class="course-detail">({{item.valid}}/{{item.total}}，请假 {{item.leave}})</text>
        </view>
      </view>
      <view wx:else class="empty-tip">暂无课程记录</view>
    </view>

    <!-- 缺勤明细 -->
    <view class="section" wx:if="{{studentAbsentList.length > 0}}">
      <view class="section-title">⚠️ 缺勤记录</view>
      <view class="absent-item" wx:for="{{studentAbsentList}}" wx:key="index">
        <text>{{item.course_name}}</text>
        <text class="absent-date">{{item.session_date}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 教师视图 ===== -->
  <view wx:elif="{{role === 'teacher'}}" class="teacher-view">
    <!-- 班级选择器 -->
    <view class="picker-section" wx:if="{{teacherClasses.length > 0}}">
      <text>选择班级：</text>
      <picker mode="selector" range="{{teacherClasses}}" range-key="class_id" bindchange="onClassChange" value="{{selectedClassIndex}}">
        <view class="picker-display">
          <text>{{teacherClasses[selectedClassIndex].class_id}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 班级详情 -->
    <view wx:if="{{selectedClassDetail}}" class="class-detail">
      <view class="class-summary">
        <text class="class-rate">出勤率 {{selectedClassDetail.attendance_rate}}%</text>
        <text class="class-meta">场次 {{selectedClassDetail.total_sessions}} | 选课 {{selectedClassDetail.total_students}}人</text>
      </view>

      <!-- 缺勤学生列表 -->
      <view class="section">
        <view class="section-title">📋 缺勤学生名单</view>
        <view wx:if="{{selectedClassDetail.absentStudents.length > 0}}">
          <view class="absent-student" wx:for="{{selectedClassDetail.absentStudents}}" wx:key="student_id">
            <text>{{item.name}} ({{item.student_id}})</text>
            <text class="absent-count">缺勤 {{item.absent_count}} 次</text>
          </view>
        </view>
        <view wx:else class="empty-tip">🎉 该班无缺勤学生</view>
      </view>
    </view>

    <!-- 所有班级列表 -->
    <view class="section">
      <view class="section-title">📊 所有班级出勤率</view>
      <view wx:if="{{teacherClasses.length > 0}}">
        <view class="class-overview-item" wx:for="{{teacherClasses}}" wx:key="class_id">
          <text class="class-id">{{item.class_id}}</text>
          <text class="class-rate-mini">出勤率 {{item.attendance_rate}}%</text>
        </view>
      </view>
      <view wx:else class="empty-tip">暂无班级数据</view>
    </view>
  </view>

  <!-- 底部刷新按钮 -->
  <view class="footer-actions">
    <button class="refresh-btn" bindtap="handleRefresh">🔄 刷新数据</button>
  </view>
</view>