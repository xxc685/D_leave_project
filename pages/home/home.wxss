/* ========== 全局容器 ========== */
.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fb 0%, #ffffff 40%);
  padding: 40rpx 36rpx;
  box-sizing: border-box;
}

/* ========== 问候语区域 ========== */
.greeting-section {
  display: flex;
  flex-direction: column;
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.greeting-date {
  font-size: 26rpx;
  color: #999;
}

/* ========== 主体操作卡片 ========== */
.action-card {
  display: flex;
  align-items: center;
  padding: 44rpx 36rpx;
  border-radius: 28rpx;
  margin-bottom: 48rpx;
  transition: transform 0.2s ease;
}

.card-hover {
  transform: scale(0.97);
  opacity: 0.9;
}

.student-card {
  background: linear-gradient(135deg, #07C160 0%, #00B37A 100%);
  box-shadow: 0 16rpx 40rpx rgba(7, 193, 96, 0.3);
}

.teacher-card {
  background: linear-gradient(135deg, #4A90E2 0%, #3B7DD8 100%);
  box-shadow: 0 16rpx 40rpx rgba(74, 144, 226, 0.3);
}

.card-icon {
  font-size: 64rpx;
  margin-right: 28rpx;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

.card-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 300;
}

/* ========== 未登录空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
}

/* ========== 快捷功能区域 ========== */
.quick-actions {
  margin-top: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #888;
  padding: 0 8rpx;
  margin-bottom: 24rpx;
  display: block;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.quick-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.quick-label {
  font-size: 22rpx;
  color: #666;
}
