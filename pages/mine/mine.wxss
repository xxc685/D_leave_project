/* ========== 全局容器 ========== */
.mine-container {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 40rpx;
}

/* ========== 用户信息卡片 ========== */
.profile-card {
  display: flex;
  align-items: center;
  padding: 56rpx 40rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #4A90E2, #6CB3F5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.25);
}

.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 10rpx;
}

.profile-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.profile-role {
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  padding: 4rpx 20rpx;
  border-radius: 8rpx;
}

.profile-id {
  font-size: 24rpx;
  color: #999;
}

/* ========== 功能菜单 ========== */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 28rpx 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
  width: 44rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

/* ========== 退出登录 ========== */
.logout-area {
  padding: 32rpx 40rpx;
}

.logout-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 46rpx;
  font-size: 30rpx;
  color: #E74C3C;
  background: #fff;
  border: 2rpx solid #FFE0E0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 40rpx 0;
}

.version-info text {
  font-size: 22rpx;
  color: #ccc;
}
